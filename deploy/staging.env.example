# HWallet staging backend environment template.
# Copy this file on the server only. Never commit real values.

NODE_ENV=production
PORT=3000

# Storage
HWALLET_SESSION_STORE=postgres
DATABASE_POOL_MAX=2
DATABASE_URL=postgresql://postgres:REPLACE_ME@db.example.supabase.co:5432/postgres

# Auth boundary
AGENT_REQUIRE_OWNER=true
AGENT_REQUIRE_PRIVY_TOKEN=true
NEXT_PUBLIC_PRIVY_APP_ID=REPLACE_ME
NEXT_PUBLIC_PRIVY_CLIENT_ID=REPLACE_ME
PRIVY_APP_SECRET=REPLACE_ME

# X Layer read-only wallet support
NEXT_PUBLIC_XLAYER_RPC_URL=https://rpc.xlayer.tech
XLAYER_RPC_URL=https://rpc.xlayer.tech
XLAYER_FALLBACK_RPC_URL=https://xlayerrpc.okx.com

# OKX Outcomes / prediction data, if enabled for data display.
PREDICTIONS_API_KEY=REPLACE_ME
PREDICTIONS_API_SECRET=REPLACE_ME
PREDICTIONS_API_PASSPHRASE=REPLACE_ME

# Mobile app API URL. Use your public HTTPS server URL.
EXPO_PUBLIC_API_BASE_URL=https://api.example.com

# Live execution must stay closed for staging MVP.
AGENT_WALLET_REAL_EXECUTION=false
ONCHAINOS_LIVE_MODE=false
POLYMARKET_LIVE_MODE=false
POLYMARKET_TRADING_API_ENABLED=false
