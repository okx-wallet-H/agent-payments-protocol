# Public Privy app id for the frontend once Privy is enabled.
NEXT_PUBLIC_PRIVY_APP_ID=
NEXT_PUBLIC_PRIVY_CLIENT_ID=

# Server-side Privy credentials should only be used from API routes.
PRIVY_APP_SECRET=

# Access control. Local smoke tests may keep AGENT_REQUIRE_PRIVY_TOKEN=false,
# but staging/production should require verified Privy Bearer tokens.
AGENT_REQUIRE_OWNER=true
AGENT_REQUIRE_PRIVY_TOKEN=true

# Optional RPC override. Defaults are in lib/xlayer.ts.
XLAYER_RPC_URL=https://rpc.xlayer.tech
XLAYER_FALLBACK_RPC_URL=https://xlayerrpc.okx.com

# Optional OKX Open API credentials for future Onchain OS integrations.
OKX_ACCESS_KEY=
OKX_ACCESS_SECRET=
OKX_ACCESS_PASSPHRASE=

# Optional OKX Outcomes data source.
# auto: try OKX Outcomes, then plugin data, then local sample.
# live: try OKX Outcomes; if unavailable, return local sample with a friendly status.
# plugin: skip OKX Outcomes and use plugin data first.
# sample: always use local sample data for demos.
OKX_OUTCOMES_DATA_MODE=auto
PREDICTIONS_API_KEY=
PREDICTIONS_API_SECRET=
PREDICTIONS_API_PASSPHRASE=

# Optional Builder Code for EOA/ERC-7702 attribution.
OKX_BUILDER_CODE=

# Production storage. Local MVP still uses data/db.json when DATABASE_URL is unset.
DATABASE_URL=
# Optional. Set to false only when a managed Postgres pooler requires SSL but
# local Node certificate verification rejects its chain. Supabase pooler hosts
# are handled automatically by the app connection helper.
DATABASE_SSL_REJECT_UNAUTHORIZED=
# HWallet V2 session/wallet storage:
# jsonl: default local mode, no database dependency.
# dual: read local JSONL and mirror HWallet session/wallet data into Postgres.
# postgres: read/write HWallet session/wallet data from Postgres.
HWALLET_SESSION_STORE=jsonl
# Optional Supabase/pg pool ceiling. Keep low with Supabase session pooler.
DATABASE_POOL_MAX=2
REDIS_URL=
TRAINING_DATA_BUCKET=
TRAINING_DATA_PUBLIC_BASE_URL=
VECTOR_DATABASE_URL=

# Agent Brain. Leave as local-rules for deterministic MVP behavior.
AGENT_BRAIN_PROVIDER=local-rules
AGENT_BRAIN_MODEL=
OPENAI_API_KEY=

# Live trading gates. Keep false unless production risk review is complete.
ONCHAINOS_LIVE_MODE=false
POLYMARKET_LIVE_MODE=false
AGENT_WALLET_REAL_EXECUTION=false
POLYMARKET_TRADING_API_ENABLED=false

# Mobile app API base URL.
# iOS simulator can use http://localhost:3000.
# Android emulator usually needs http://10.0.2.2:3000.
# Physical devices need your LAN URL, for example http://192.168.1.10:3000.
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000

# Readiness gates.
# Local: npm run smoke:production-readiness
# Staging: STAGING_READINESS=true npm run smoke:production-readiness
STAGING_READINESS=false
# Mobile local: npm run smoke:mobile-build-env
# Physical device: MOBILE_DEVICE_READINESS=true npm run smoke:mobile-build-env
# Staging/TestFlight: MOBILE_STAGING_READINESS=true npm run smoke:mobile-build-env
MOBILE_DEVICE_READINESS=false
MOBILE_STAGING_READINESS=false

# Privy mobile app client config. The client ID is required by Privy's Expo SDK.
EXPO_PUBLIC_PRIVY_APP_ID=
EXPO_PUBLIC_PRIVY_CLIENT_ID=
