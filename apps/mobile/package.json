{
  "name": "agent-wallet-mobile",
  "version": "0.1.0",
  "private": true,
  "main": "expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "start:v2": "EXPO_PUBLIC_AGENT_WALLET_V2_UI=true expo start",
    "start:v2:preview": "EXPO_PUBLIC_AGENT_WALLET_PREVIEW=true expo start",
    "ios": "expo start --ios",
    "ios:v2": "EXPO_PUBLIC_AGENT_WALLET_V2_UI=true expo start --ios",
    "android": "expo start --android",
    "android:v2": "EXPO_PUBLIC_AGENT_WALLET_V2_UI=true expo start --android",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "eas:whoami": "eas whoami",
    "eas:init": "eas init",
    "release:preflight": "npm --prefix ../.. run smoke:mobile-release-preflight",
    "prebuild:ios:development-staging": "npm run release:preflight",
    "build:ios:development-staging": "eas build --platform ios --profile development-staging",
    "prebuild:android:development-staging": "npm run release:preflight",
    "build:android:development-staging": "eas build --platform android --profile development-staging",
    "prebuild:ios:preview": "npm run release:preflight",
    "build:ios:preview": "eas build --platform ios --profile preview",
    "prebuild:android:preview": "npm run release:preflight",
    "build:android:preview": "eas build --platform android --profile preview",
    "prebuild:ios": "npm run release:preflight",
    "build:ios": "eas build --platform ios --profile production",
    "prebuild:android": "npm run release:preflight",
    "build:android": "eas build --platform android --profile production",
    "preupdate:development-staging": "npm run release:preflight",
    "update:development-staging": "EXPO_PUBLIC_API_BASE_URL=https://app.hwallet.vip EXPO_PUBLIC_AGENT_WALLET_V2_UI=true eas update --channel development-staging --environment preview",
    "preupdate:preview": "npm run release:preflight",
    "update:preview": "EXPO_PUBLIC_API_BASE_URL=https://app.hwallet.vip EXPO_PUBLIC_AGENT_WALLET_V2_UI=true eas update --channel preview --environment preview",
    "preupdate:production": "npm run release:preflight",
    "update:production": "EXPO_PUBLIC_API_BASE_URL=https://app.hwallet.vip EXPO_PUBLIC_AGENT_WALLET_V2_UI=true eas update --channel production --environment production",
    "presubmit:ios": "npm run release:preflight",
    "submit:ios": "eas submit --platform ios --profile production",
    "presubmit:android": "npm run release:preflight",
    "submit:android": "eas submit --platform android --profile production"
  },
  "dependencies": {
    "@ethersproject/shims": "^5.8.0",
    "@expo/vector-icons": "15.1.1",
    "@privy-io/expo": "^0.69.0",
    "@privy-io/expo-native-extensions": "^0.0.11",
    "buffer": "^6.0.3",
    "expo": "56.0.9",
    "expo-apple-authentication": "~56.0.4",
    "expo-application": "~56.0.3",
    "expo-clipboard": "^56.0.4",
    "expo-constants": "~56.0.17",
    "expo-crypto": "~56.0.4",
    "expo-dev-client": "~56.0.20",
    "expo-font": "~56.0.5",
    "expo-linking": "~56.0.13",
    "expo-secure-store": "~56.0.4",
    "expo-status-bar": "~56.0.4",
    "expo-updates": "~56.0.19",
    "expo-web-browser": "~56.0.5",
    "fast-text-encoding": "^1.0.6",
    "react": "19.2.3",
    "react-dom": "^19.2.3",
    "react-native": "0.85.3",
    "react-native-get-random-values": "~1.11.0",
    "react-native-passkeys": "^0.4.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-web": "^0.21.2",
    "react-native-webview": "13.16.1",
    "viem": "2.52.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.7",
    "eas-cli": "^20.1.0",
    "typescript": "~6.0.3"
  },
  "overrides": {
    "uuid": "11.1.1"
  }
}
