{
  "cli": {
    "version": "20.1.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "http://localhost:3000"
      }
    },
    "development-staging": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://app.hwallet.vip",
        "EXPO_PUBLIC_AGENT_WALLET_V2_UI": "true"
      }
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://app.hwallet.vip",
        "EXPO_PUBLIC_AGENT_WALLET_V2_UI": "true",
        "EXPO_PUBLIC_AGENT_WALLET_PREVIEW": "true"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://app.hwallet.vip",
        "EXPO_PUBLIC_AGENT_WALLET_V2_UI": "true"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
