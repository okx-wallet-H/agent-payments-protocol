{
  "cli": {
    "version": "20.1.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "http://localhost:3000"
      },
      "channel": "development"
    },
    "development-staging": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://app.hwallet.vip",
        "EXPO_PUBLIC_AGENT_WALLET_V2_UI": "true"
      },
      "channel": "development-staging"
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://app.hwallet.vip",
        "EXPO_PUBLIC_AGENT_WALLET_V2_UI": "true",
        "EXPO_PUBLIC_AGENT_WALLET_PREVIEW": "true"
      },
      "channel": "preview"
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://app.hwallet.vip",
        "EXPO_PUBLIC_AGENT_WALLET_V2_UI": "true"
      },
      "channel": "production"
    }
  },
  "submit": {
    "production": {}
  }
}
