{
  "expo": {
    "name": "Agent Wallet",
    "slug": "agent-wallet-xlayer-mvp",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "agentwallet",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.agentwallet.xlayer",
      "buildNumber": "3",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.agentwallet.xlayer",
      "versionCode": 3,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0D7A53"
      },
      "permissions": []
    },
    "extra": {
      "eas": {
        "projectId": "7fb6881a-af55-401c-9d96-fa4a789dc4da"
      }
    },
    "plugins": [
      "expo-secure-store",
      "expo-web-browser"
    ]
  }
}
